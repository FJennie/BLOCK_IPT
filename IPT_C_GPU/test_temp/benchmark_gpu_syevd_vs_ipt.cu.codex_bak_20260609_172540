static void csv_clean(char *text)
{
    for (char *p = text; *p != '\0'; ++p) {
        if (*p == ',' || *p == '\n' || *p == '\r') {
            *p = ';';
        }
    }
}

static void write_header(const Config *cfg)
{
    FILE *fp = fopen(cfg->result_csv, "w");

    if (fp == NULL) {
        fprintf(stderr, "could not open %s: %s\n", cfg->result_csv,
                strerror(errno));
        exit(2);
    }

    fprintf(fp,
            "N,epsilon,time_syevd_sec,time_ipt_sec,residual_syevd,"
            "residual_ipt,gpu_name,status,error\n");
    fclose(fp);
}

static void append_row(const Config *cfg, int n, const MethodResult *syevd,
                       const MethodResult *ipt, const char *gpu_name,
                       const char *status, const char *error)
{
    FILE *fp = fopen(cfg->result_csv, "a");
    char gpu_clean[256];
    char status_clean[64];
    char error_clean[1024];

    if (fp == NULL) {
        fprintf(stderr, "could not append %s: %s\n", cfg->result_csv,
                strerror(errno));
        return;
    }

    snprintf(gpu_clean, sizeof(gpu_clean), "%s", gpu_name);
    snprintf(status_clean, sizeof(status_clean), "%s", status);
    snprintf(error_clean, sizeof(error_clean), "%s", error);
    csv_clean(gpu_clean);
    csv_clean(status_clean);
    csv_clean(error_clean);

    fprintf(fp, "%d,%.17g,%.17g,%.17g,%.17g,%.17g,%s,%s,%s\n", n,
            cfg->epsilon, syevd->time_sec, ipt->time_sec, syevd->residual,
            ipt->residual, gpu_clean, status_clean, error_clean);
    fclose(fp);
}

