static double now_seconds(void)
{
    struct timespec ts;

    clock_gettime(CLOCK_MONOTONIC, &ts);
    return (double)ts.tv_sec + (double)ts.tv_nsec * 1.0e-9;
}

static void wall_time_string(char *buffer, size_t size)
{
    time_t t = time(NULL);
    struct tm tm_value;

    localtime_r(&t, &tm_value);
    strftime(buffer, size, "%Y-%m-%dT%H:%M:%S%z", &tm_value);
}

static int ensure_directory(const char *path)
{
    if (mkdir(path, 0775) == 0 || errno == EEXIST) {
        return 0;
    }

    fprintf(stderr, "could not create directory %s: %s\n", path,
            strerror(errno));
    return -1;
}

static const char *env_or_default(const char *name, const char *default_value)
{
    const char *value = getenv(name);

    return (value == NULL || value[0] == '\0') ? default_value : value;
}

static int parse_bool_env(const char *name, int default_value)
{
    const char *value = getenv(name);

    if (value == NULL || value[0] == '\0') {
        return default_value;
    }

    return strcmp(value, "1") == 0 || strcasecmp(value, "true") == 0 ||
           strcasecmp(value, "yes") == 0 || strcasecmp(value, "y") == 0;
}

static void parse_ns(Config *cfg)
{
    const char *raw = getenv("IPT_BENCH_NS");
    const int defaults[] = {32,   64,   128,  256,  512,
                            1024, 2048, 4096, 8192, 16384};

    cfg->n_count = 0;

    if (raw == NULL || raw[0] == '\0') {
        for (int i = 0; i < (int)(sizeof(defaults) / sizeof(defaults[0]));
             ++i) {
            cfg->ns[cfg->n_count++] = defaults[i];
        }
        return;
    }

    {
        char *copy = strdup(raw);
        char *token = NULL;

        if (copy == NULL) {
            fprintf(stderr, "strdup failed while parsing IPT_BENCH_NS\n");
            exit(2);
        }

        token = strtok(copy, ",");
        while (token != NULL && cfg->n_count < MAX_NS) {
            while (*token == ' ' || *token == '\t') {
                ++token;
            }
            if (*token != '\0') {
                cfg->ns[cfg->n_count++] = atoi(token);
            }
            token = strtok(NULL, ",");
        }
        free(copy);
    }

    if (cfg->n_count == 0) {
        fprintf(stderr, "IPT_BENCH_NS did not contain any valid N values\n");
        exit(2);
    }
}

static void load_config(Config *cfg)
{
    memset(cfg, 0, sizeof(*cfg));

    cfg->root = env_or_default("IPT_C_ROOT", DEFAULT_ROOT);
    cfg->results_dir = env_or_default("IPT_C_RESULTS_DIR", NULL);
    cfg->logs_dir = env_or_default("IPT_C_LOG_DIR", NULL);

    if (cfg->results_dir == NULL) {
        static char default_results[4096];
        snprintf(default_results, sizeof(default_results), "%s/results",
                 cfg->root);
        cfg->results_dir = default_results;
    }

    if (cfg->logs_dir == NULL) {
        static char default_logs[4096];
        snprintf(default_logs, sizeof(default_logs), "%s/logs", cfg->root);
        cfg->logs_dir = default_logs;
    }

    cfg->epsilon =
        getenv("IPT_EPSILON") ? atof(getenv("IPT_EPSILON")) : DEFAULT_EPSILON;
    cfg->iterations = getenv("IPT_ITERATIONS") ? atoi(getenv("IPT_ITERATIONS"))
                                               : DEFAULT_ITERATIONS;
    cfg->repeats =
        getenv("IPT_REPEATS") ? atoi(getenv("IPT_REPEATS")) : DEFAULT_REPEATS;
    if (cfg->repeats <= 0) {
        cfg->repeats = DEFAULT_REPEATS;
    }
    cfg->seed =
        getenv("IPT_SEED") ? strtoull(getenv("IPT_SEED"), NULL, 10)
                           : DEFAULT_SEED;
    cfg->compute_residuals = parse_bool_env("IPT_COMPUTE_RESIDUALS", 1);

    parse_ns(cfg);

    snprintf(cfg->result_csv, sizeof(cfg->result_csv),
             "%s/gpu_syevd_vs_ipt_results.csv", cfg->results_dir);
    snprintf(cfg->summary_txt, sizeof(cfg->summary_txt),
             "%s/gpu_syevd_vs_ipt_summary.txt", cfg->results_dir);
}

